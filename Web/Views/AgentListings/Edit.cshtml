@using NhaTot.Models.Enums
@model NhaTot.ViewModels.AgentPropertyEditViewModel
@{ ViewData["Title"] = Model.Id == 0 ? "Tạo tin đăng" : "Chỉnh sửa tin đăng"; }
<section class="page-heading"><div class="container"><p class="eyebrow">KHU VỰC MÔI GIỚI</p><h1>@ViewData["Title"]</h1><p>Thông tin chính xác giúp tin đăng được xét duyệt nhanh hơn.</p></div></section>
<section class="container agent-page agent-listing-edit">@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }<div class="agent-form"><div asp-validation-summary="ModelOnly" class="text-danger"></div><form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" asp-route-id="@Model.Id" method="post"><div class="row g-3">
<div class="col-12"><label asp-for="Input.Title"></label><input asp-for="Input.Title" class="form-control" /><span asp-validation-for="Input.Title" class="text-danger"></span></div><div class="col-md-6"><label asp-for="Input.Purpose"></label><select asp-for="Input.Purpose" class="form-select"><option value="">-- Chọn nhu cầu --</option><option value="@ListingPurpose.Sale">Bán</option><option value="@ListingPurpose.Rent">Cho thuê</option></select><span asp-validation-for="Input.Purpose" class="text-danger"></span></div><div class="col-md-6"><label asp-for="Input.PropertyTypeId"></label><select asp-for="Input.PropertyTypeId" class="form-select"><option value="">-- Chọn loại --</option>@foreach (var item in Model.PropertyTypes) { <option value="@item.Id">@item.Name</option> }</select><span asp-validation-for="Input.PropertyTypeId" class="text-danger"></span></div>
<div class="col-md-6"><label asp-for="Input.Price"></label><input asp-for="Input.Price" class="form-control" /><span asp-validation-for="Input.Price" class="text-danger"></span></div><div class="col-md-6"><label asp-for="Input.AreaSquareMeters"></label><input asp-for="Input.AreaSquareMeters" class="form-control" /><span asp-validation-for="Input.AreaSquareMeters" class="text-danger"></span></div><div class="col-md-6"><label asp-for="Input.Bedrooms"></label><input asp-for="Input.Bedrooms" class="form-control" /></div><div class="col-md-6"><label asp-for="Input.Bathrooms"></label><input asp-for="Input.Bathrooms" class="form-control" /></div>
<div class="col-md-6"><label asp-for="Input.ProvinceId"></label><select asp-for="Input.ProvinceId" class="form-select"><option value="">-- Chọn tỉnh/thành --</option>@foreach (var item in Model.Provinces) { <option value="@item.Id">@item.Name</option> }</select><span asp-validation-for="Input.ProvinceId" class="text-danger"></span></div><div class="col-md-6"><label asp-for="Input.DistrictId"></label><select asp-for="Input.DistrictId" class="form-select"><option value="">-- Chọn quận/huyện --</option>@foreach (var item in Model.Districts) { <option value="@item.Id">@item.Name</option> }</select><span asp-validation-for="Input.DistrictId" class="text-danger"></span></div>
<div class="col-12"><label asp-for="Input.Address"></label><input asp-for="Input.Address" class="form-control" /><span asp-validation-for="Input.Address" class="text-danger"></span></div><div class="col-12"><label asp-for="Input.ApproximateLocation"></label><input asp-for="Input.ApproximateLocation" class="form-control" /></div><div class="col-12"><label asp-for="Input.Description"></label><textarea asp-for="Input.Description" class="form-control" rows="7"></textarea><span asp-validation-for="Input.Description" class="text-danger"></span></div>
<div class="col-12"><label asp-for="Input.AmenityIds"></label><div class="amenity-checkboxes">@foreach (var item in Model.Amenities) { <label><input type="checkbox" name="Input.AmenityIds" value="@item.Id" checked="@Model.Input.AmenityIds.Contains(item.Id)" /> @item.Name</label> }</div></div></div><div class="mt-4 d-flex gap-2"><button class="btn btn-primary" type="submit">Lưu bản nháp</button><a class="btn btn-outline-primary" asp-action="Index">Quay lại</a>@if (Model.Id != 0) { <a class="btn btn-outline-primary" asp-action="Preview" asp-route-id="@Model.Id">Xem trước</a> }</div></form></div>
@if (Model.Id != 0) { <section class="agent-form listing-images"><h2>Ảnh tin đăng</h2><p>Chỉ chấp nhận liên kết ảnh HTTPS.</p><form asp-action="AddImage" asp-route-id="@Model.Id" method="post" class="row g-2"><div class="col-md-6"><input name="FilePath" class="form-control" placeholder="https://..." required /></div><div class="col-md-4"><input name="AltText" class="form-control" placeholder="Mô tả ảnh" /></div><div class="col-md-2"><label><input type="checkbox" name="IsCover" value="true" /> Ảnh bìa</label></div><div class="col-12"><button class="btn btn-outline-primary" type="submit">Thêm ảnh</button></div></form>@if (Model.Images.Any()) { <div class="image-manager">@foreach (var image in Model.Images) { <article><img src="@image.FilePath" alt="@image.AltText" /><div>@if (image.IsCover) { <span>Ảnh bìa</span> }<form asp-action="DeleteImage" asp-route-id="@Model.Id" asp-route-imageId="@image.Id" method="post"><button class="btn btn-link text-danger" type="submit">Xóa</button></form></div></article> }</div> }</section> }
</section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
