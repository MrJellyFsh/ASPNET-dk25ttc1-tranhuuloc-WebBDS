@using NhaTot.Models.Enums
@model NhaTot.ViewModels.AgentDashboardViewModel
@{ ViewData["Title"] = "Bảng điều khiển môi giới"; }
<section class="page-heading"><div class="container"><p class="eyebrow">KHU VỰC MÔI GIỚI</p><h1>Quản lý tin đăng</h1><p>Theo dõi và cập nhật các tin thuộc tài khoản của bạn.</p></div></section>
<section class="container agent-listings">
@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (TempData["InfoMessage"] is string info) { <div class="alert alert-info">@info</div> }
<div class="agent-listings__toolbar"><h2>Tin đăng của bạn</h2><a class="btn btn-primary" asp-action="Create">Tạo tin mới</a></div>
@if (!Model.Properties.Any()) { <div class="empty-state"><h2>Bạn chưa có tin đăng</h2><p>Bắt đầu tạo bản nháp đầu tiên để chuẩn bị gửi xét duyệt.</p></div> } else { <div class="agent-listings__table"><table><thead><tr><th>Tiêu đề</th><th>Trạng thái</th><th>Ngày tạo</th><th>Cập nhật</th><th></th></tr></thead><tbody>@foreach (var property in Model.Properties) { <tr><td><strong>@property.Title</strong><small>@property.PropertyTypeName · @property.Price.ToString("N0") VNĐ</small></td><td><span class="status-badge">@property.Status switch { PropertyStatus.Draft => "Nháp", PropertyStatus.PendingReview => "Chờ duyệt", PropertyStatus.Approved => "Đã duyệt", PropertyStatus.Rejected => "Cần chỉnh sửa", PropertyStatus.Hidden => "Đã ẩn", _ => "Đã đóng" }</span></td><td>@property.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td><td>@property.UpdatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td><td class="agent-actions"><a asp-action="Preview" asp-route-id="@property.Id">Xem</a>@if (property.Status is PropertyStatus.Draft or PropertyStatus.Rejected) { <a asp-action="Edit" asp-route-id="@property.Id">Sửa</a><form asp-action="Submit" asp-route-id="@property.Id" method="post"><button type="submit" class="btn btn-link">Gửi duyệt</button></form> }</td></tr> }</tbody></table></div> }
</section>
