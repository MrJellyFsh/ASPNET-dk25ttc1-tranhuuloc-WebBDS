@using NhaTot.Models.Enums
@model NhaTot.ViewModels.AgentPropertyPreviewViewModel
@{ ViewData["Title"] = "Xem trước tin đăng"; }
<section class="page-heading"><div class="container"><p class="eyebrow">BẢN XEM TRƯỚC RIÊNG TƯ</p><h1>@Model.Title</h1><p>Chỉ bạn mới xem được bản xem trước này.</p></div></section><section class="container property-detail"><div class="property-detail__layout"><div><div class="detail-gallery">@if (Model.Images.Any()) { @foreach (var image in Model.Images) { <img src="@image.FilePath" alt="@image.AltText" /> } } else { <div class="detail-gallery__empty">⌂</div> }</div><article class="detail-section"><p class="detail-price">@Model.Price.ToString("N0") VNĐ</p><p class="detail-facts"><span>@Model.AreaSquareMeters m²</span>@if (Model.Bedrooms is not null) { <span>@Model.Bedrooms phòng ngủ</span> }</p><p><strong>Địa chỉ đầy đủ:</strong> @Model.Address</p></article><article class="detail-section"><h2>Mô tả</h2><div class="detail-description">@Model.Description</div></article></div><aside class="detail-sidebar"><div class="contact-form"><h2>Trạng thái</h2><p>@(Model.Status switch { PropertyStatus.Draft => "Nháp", PropertyStatus.PendingReview => "Chờ duyệt", PropertyStatus.Approved => "Đã duyệt", PropertyStatus.Rejected => "Cần chỉnh sửa", PropertyStatus.Hidden => "Đã ẩn", _ => "Đã đóng" })</p><a class="btn btn-primary" asp-action="Edit" asp-route-id="@ViewContext.RouteData.Values["id"]">Quay lại chỉnh sửa</a></div></aside></div></section>
