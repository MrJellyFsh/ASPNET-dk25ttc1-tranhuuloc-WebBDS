@using NhaTot.Models.Enums
@model NhaTot.ViewModels.AdminPropertyModerationDetailsViewModel
@{ ViewData["Title"] = "Kiểm duyệt tin đăng"; }
<section class="page-heading"><div class="container"><p class="eyebrow">QUẢN TRỊ</p><h1>@Model.Title</h1><p>Bản kiểm duyệt nội bộ, không công khai.</p></div></section>
<section class="container property-detail"><a asp-action="Properties" class="btn btn-link px-0">← Danh sách chờ duyệt</a>@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }<div class="property-detail__layout"><div><div class="detail-gallery">@if (Model.ImageUrls.Any()) { @foreach (var url in Model.ImageUrls) { <img src="@url" alt="Ảnh tin đăng" /> } } else { <div class="detail-gallery__empty">⌂</div> }</div><article class="detail-section"><p class="detail-price">@Model.Price.ToString("N0") VNĐ</p><p class="detail-facts"><span>@Model.AreaSquareMeters m²</span>@if (Model.Bedrooms is not null) { <span>@Model.Bedrooms phòng ngủ</span> }</p><p><strong>Địa chỉ đầy đủ:</strong> @Model.Address</p><p><strong>Khu vực công khai:</strong> @Model.ApproximateLocation</p></article><article class="detail-section"><h2>Mô tả</h2><div class="detail-description">@Model.Description</div></article>@if (Model.Amenities.Any()) { <article class="detail-section"><h2>Tiện ích</h2><p>@string.Join(", ", Model.Amenities)</p></article> }</div><aside class="detail-sidebar"><div class="contact-form"><h2>Quyết định</h2><form asp-action="ApproveProperty" asp-route-id="@Model.Id" method="post"><button class="btn btn-success w-100 mb-2" type="submit">Duyệt và công khai</button></form><button class="btn btn-outline-danger w-100" type="button" data-bs-toggle="collapse" data-bs-target="#reject-form">Từ chối</button><div class="collapse mt-3" id="reject-form"><form asp-action="RejectProperty" asp-route-id="@Model.Id" method="post"><label class="form-label" for="Reason">Lý do từ chối</label><textarea id="Reason" name="Reason" class="form-control" maxlength="1000" required></textarea><button class="btn btn-danger w-100 mt-2" type="submit">Xác nhận từ chối</button></form></div></div></aside></div></section>
