@model IReadOnlyList<NhaTot.ViewModels.AdminAgentApplicationSummaryViewModel>
@{ ViewData["Title"] = "Xét duyệt hồ sơ môi giới"; }
<section class="page-heading"><div class="container"><p class="eyebrow">QUẢN TRỊ</p><h1>Hồ sơ môi giới chờ duyệt</h1></div></section>
<section class="container agent-page">@if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> } @if (!Model.Any()) { <p class="text-muted">Không có hồ sơ nào chờ xét duyệt.</p> } else { <div class="table-responsive"><table class="table"><thead><tr><th>Họ tên</th><th>Công ty</th><th>Khu vực</th><th>Gửi lúc</th><th></th></tr></thead><tbody>@foreach (var item in Model) { <tr><td>@item.FullName</td><td>@item.CompanyName</td><td>@item.OperatingArea</td><td>@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td><td><a asp-action="AgentApplicationDetails" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Xem</a></td></tr> }</tbody></table></div> }</section>
