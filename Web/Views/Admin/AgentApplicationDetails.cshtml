@model NhaTot.ViewModels.AdminAgentApplicationDetailsViewModel
@{ ViewData["Title"] = "Xét duyệt hồ sơ môi giới"; }
<section class="page-heading"><div class="container"><p class="eyebrow">QUẢN TRỊ</p><h1>Xét duyệt hồ sơ môi giới</h1></div></section>
<section class="container agent-page"><a asp-action="AgentApplications" class="btn btn-link px-0">← Danh sách chờ duyệt</a>@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }<div class="agent-status-card"><dl class="agent-profile-summary"><dt>Họ tên</dt><dd>@Model.FullName</dd><dt>Email</dt><dd>@Model.Email</dd><dt>Số điện thoại</dt><dd>@Model.PhoneNumber</dd><dt>Công ty</dt><dd>@Model.CompanyName</dd><dt>Khu vực hoạt động</dt><dd>@Model.OperatingArea</dd><dt>Kinh nghiệm</dt><dd>@(Model.YearsOfExperience?.ToString() ?? "Chưa cung cấp")</dd><dt>Giới thiệu</dt><dd>@Model.Introduction</dd>@if (!string.IsNullOrWhiteSpace(Model.VerificationDocumentPath)) { <dt>Tài liệu xác minh</dt><dd>@Model.VerificationDocumentPath</dd> }</dl><div class="d-flex flex-wrap gap-2"><form asp-action="ApproveAgentApplication" asp-route-id="@Model.Id" method="post"><button class="btn btn-success" type="submit">Duyệt hồ sơ</button></form><button class="btn btn-outline-danger" type="button" data-bs-toggle="collapse" data-bs-target="#reject-form">Từ chối</button></div><div class="collapse mt-3" id="reject-form"><form asp-action="RejectAgentApplication" asp-route-id="@Model.Id" method="post"><label class="form-label" for="Reason">Lý do từ chối</label><textarea id="Reason" name="Reason" class="form-control" maxlength="1000" required></textarea><button class="btn btn-danger mt-2" type="submit">Xác nhận từ chối</button></form></div></div></section>
