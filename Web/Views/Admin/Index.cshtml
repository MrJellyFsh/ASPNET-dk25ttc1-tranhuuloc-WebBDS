@model NhaTot.ViewModels.AdminDashboardViewModel
@{ ViewData["Title"] = "Quản trị và kiểm duyệt"; }
<section class="page-heading"><div class="container"><p class="eyebrow">QUẢN TRỊ</p><h1>Hàng chờ xét duyệt</h1><p>Chỉ hiển thị dữ liệu phục vụ việc xét duyệt.</p></div></section>
<section class="container agent-page">
    @if (TempData["SuccessMessage"] is string success) { <div class="alert alert-success">@success</div> }
    @if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }
    <div class="d-flex justify-content-between align-items-center mb-3"><h2>Hồ sơ môi giới chờ duyệt</h2><a asp-action="AgentApplications" class="btn btn-outline-primary">Xem tất cả</a></div>
    @if (!Model.PendingAgentApplications.Any()) { <p class="text-muted">Không có hồ sơ nào chờ xét duyệt.</p> } else { <div class="table-responsive"><table class="table"><thead><tr><th>Họ tên</th><th>Khu vực</th><th>Gửi lúc</th><th></th></tr></thead><tbody>@foreach (var item in Model.PendingAgentApplications) { <tr><td>@item.FullName</td><td>@item.OperatingArea</td><td>@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td><td><a asp-action="AgentApplicationDetails" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Xét duyệt</a></td></tr> }</tbody></table></div> }
    <div class="d-flex justify-content-between align-items-center mt-5 mb-3"><h2>Tin đăng chờ duyệt</h2><a asp-action="Properties" class="btn btn-outline-primary">Xem tất cả</a></div>
    @if (!Model.PendingProperties.Any()) { <p class="text-muted">Không có tin đăng nào chờ xét duyệt.</p> } else { <div class="table-responsive"><table class="table"><thead><tr><th>Tiêu đề</th><th>Loại</th><th>Khu vực</th><th></th></tr></thead><tbody>@foreach (var item in Model.PendingProperties) { <tr><td>@item.Title</td><td>@item.PropertyTypeName</td><td>@item.ApproximateLocation</td><td><a asp-action="PropertyDetails" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Kiểm duyệt</a></td></tr> }</tbody></table></div> }
</section>
